SPOTIFYBU_IMAGE=ghcr.io/thedinz/spotifybu:dev
SPOTIFYBU_PORT=3000
# Optional for local HTTP. Set this to the exact public URL for reverse-proxy
# installs, for example https://spotifybu.example.com. Leave blank only when
# proxy headers produce the correct Spotify redirect URI.
NEXT_PUBLIC_APP_URL=

# Required: generate a long random value before running Docker.
# This signs SpotifyBU's own login cookies. It is not Spotify's Client Secret.
SPOTIFYBU_APP_SECRET=

# Set true when accessing SpotifyBU only over HTTPS. Keep false for local HTTP.
SPOTIFYBU_SECURE_COOKIES=false

# Required: host path to the music folder Navidrome scans.
NAVIDROME_MUSIC_PATH=/path/to/navidrome/music

# Spotify Developer Dashboard app Client ID.
# SpotifyBU uses PKCE and does not need the Spotify Client Secret.
SPOTIFY_CLIENT_ID=

# Use your Navidrome URL as seen by the SpotifyBU container.
NAVIDROME_URL=http://host.docker.internal:4533

# Optional: used to ping Navidrome and request a server-side library scan after
# SpotifyBU stages or indexes files. The mounted music folder is still required.
NAVIDROME_USERNAME=
NAVIDROME_PASSWORD=
