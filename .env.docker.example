SPOTIFYBU_IMAGE=ghcr.io/thedinz/spotifybu:dev
SPOTIFYBU_PORT=3000
# Optional for local HTTP. Set this to the exact public URL for reverse-proxy
# installs, for example https://spotifybu.example.com. Leave blank only when
# proxy headers produce the correct Spotify redirect URI.
NEXT_PUBLIC_APP_URL=

# Required: generate a long random value before running Docker.
# This signs SpotifyBU's own login cookies. It is not Spotify's Client Secret.
SPOTIFYBU_APP_SECRET=

# Set true when accessing SpotifyBU only over HTTPS. Keep false for local HTTP.
SPOTIFYBU_SECURE_COOKIES=false

# Optional: set external when Authentik or another trusted reverse proxy handles
# access control. Internal keeps SpotifyBU's built-in login form enabled.
SPOTIFYBU_AUTH_MODE=internal

# Optional: override the default /config/spotifybu.sqlite database location.
SPOTIFYBU_DATABASE_PATH=

# Required: host path to your local music library folder.
MUSIC_LIBRARY_HOST_PATH=/path/to/music-library/music

# Spotify Developer Dashboard app Client ID.
# SpotifyBU uses PKCE and does not need the Spotify Client Secret.
SPOTIFY_CLIENT_ID=

# Optional: Subsonic-compatible music server URL as seen by the SpotifyBU container.
MUSIC_LIBRARY_URL=http://host.docker.internal:4533

# Optional: used to ping the music server and request a server-side library scan
# after SpotifyBU stages or indexes files. The mounted music folder is still required.
MUSIC_LIBRARY_USERNAME=
MUSIC_LIBRARY_PASSWORD=

# Legacy Navidrome variable names are still accepted for existing installs:
# NAVIDROME_MUSIC_PATH, NAVIDROME_URL, NAVIDROME_USERNAME, NAVIDROME_PASSWORD.
# Prefer the MUSIC_LIBRARY_* names for new installs.
