GIT_BRANCH=main
SPOTIFYBU_PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Required: generate a long random value before running Docker.
SPOTIFYBU_APP_SECRET=

# Required: host path to the music folder Navidrome scans.
NAVIDROME_MUSIC_PATH=/path/to/navidrome/music

# Spotify Developer Dashboard app client ID.
SPOTIFY_CLIENT_ID=

# Use your Navidrome URL as seen by the SpotifyBU container.
NAVIDROME_URL=http://host.docker.internal:4533
